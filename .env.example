# Copy to .env and source it (or use `make run-<service>`). These match the
# docker-compose services. PULSE_HEALTH_ADDR must differ per service when running
# several on one host.

PULSE_LOG_LEVEL=info
PULSE_REGION=home
PULSE_TRACING_ENABLED=false

PULSE_POSTGRES_DSN=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable
PULSE_REDIS_ADDR=localhost:6379
PULSE_KAFKA_BROKERS=localhost:9092

# base64 of 32 bytes; replace with a real key. This example is 32 zero bytes.
PULSE_SECRET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# per-service health/metrics port (override when running multiple locally)
PULSE_HEALTH_ADDR=:8080

# --- api identity/auth (only the api service reads these, RFC-003) ---

# where the api serves the HTTP API (separate from the health/metrics addr)
PULSE_API_ADDR=:8081
# SPA origin the OAuth callback redirects back into (empty => relative redirects)
PULSE_APP_BASE_URL=http://localhost:5173
# mark session cookies Secure. true in prod; set false for dev over http
PULSE_COOKIE_SECURE=false

# JWT signing (RS256). Provide the private key inline as PEM or as a file path.
# Required in the real api (PULSE_DEV_AUTH=true bypasses this by running devapi).
PULSE_JWT_PRIVATE_KEY_PEM=
PULSE_JWT_PRIVATE_KEY_PATH=./jwt-private.pem
PULSE_JWT_ISSUER=pulse
PULSE_JWT_AUDIENCE=pulse-api
PULSE_JWT_KID=pulse-1

# OAuth providers. Configure at least one (both id and secret). A provider is wired
# only when both are present, so the api can run with just Google, just GitHub, or both.
PULSE_GOOGLE_ISSUER_URL=https://accounts.google.com
PULSE_GOOGLE_CLIENT_ID=
PULSE_GOOGLE_CLIENT_SECRET=
PULSE_GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback

PULSE_GITHUB_CLIENT_ID=
PULSE_GITHUB_CLIENT_SECRET=
PULSE_GITHUB_REDIRECT_URL=http://localhost:8081/auth/github/callback
