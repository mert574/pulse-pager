# Copy to .env and source it (or use `make run-<service>`). These match the
# docker-compose services. See the port map below for running several services at once.

PULSE_LOG_LEVEL=info
PULSE_REGION=eu-central
# Turn tracing on to export spans. With PULSE_OTLP_ENDPOINT set, spans go to the OTel
# collector (run `make up-obs` for the local collector + Tempo + Grafana stack, then
# open Grafana at http://localhost:3000 and search by trace id). Left empty, an enabled
# tracer prints spans to stdout instead.
PULSE_TRACING_ENABLED=false
PULSE_OTLP_ENDPOINT=localhost:4317

PULSE_POSTGRES_DSN=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable
PULSE_REDIS_ADDR=localhost:6379
PULSE_KAFKA_BROKERS=localhost:9092

# Event bus transport: "kafka" (default, the distributed deployment) or "redis"
# (Redis Streams, a single-node lightweight mode that reuses PULSE_REDIS_ADDR
# instead of a separate broker). With "redis", PULSE_KAFKA_BROKERS is not needed.
PULSE_BUS=kafka

# base64 of 32 bytes; replace with a real key. This example is 32 zero bytes.
PULSE_SECRET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Port map. App ports default :8080, health/metrics default :9080, so any single
# service runs with no override. To run several on one host, override per service:
#   service     app    health
#   api         8080   9080
#   billing     8081   9081
#   scheduler    -     9082
#   worker       -     9083
#   alerting     -     9084
#   notifier     -     9085
PULSE_HEALTH_ADDR=:9080

# --- api identity/auth (only the api service reads these, RFC-003) ---

# where the api serves the HTTP API (separate from the health/metrics addr)
PULSE_API_ADDR=:8080
# SPA origin the OAuth callback redirects back into (empty => relative redirects)
PULSE_APP_BASE_URL=http://localhost:5173
# mark session cookies Secure. true in prod; set false for dev over http
PULSE_COOKIE_SECURE=false

# JWT signing (RS256). Provide the private key inline as PEM or as a file path.
# Required in the real api (PULSE_DEV_AUTH=true bypasses this by running devapi).
PULSE_JWT_PRIVATE_KEY_PEM=
PULSE_JWT_PRIVATE_KEY_PATH=./jwt-private.pem
PULSE_JWT_ISSUER=pulse
PULSE_JWT_AUDIENCE=pulse-api
PULSE_JWT_KID=pulse-1

# OAuth providers. Configure at least one (both id and secret). A provider is wired
# only when both are present, so the api can run with just Google, just GitHub, or both.
PULSE_GOOGLE_ISSUER_URL=https://accounts.google.com
PULSE_GOOGLE_CLIENT_ID=
PULSE_GOOGLE_CLIENT_SECRET=
# Redirect through the SPA dev origin (Vite proxies /auth to the api), so the whole
# OAuth flow stays on http://localhost:5173 and never hits the api port directly.
PULSE_GOOGLE_REDIRECT_URL=http://localhost:5173/auth/google/callback

PULSE_GITHUB_CLIENT_ID=
PULSE_GITHUB_CLIENT_SECRET=
PULSE_GITHUB_REDIRECT_URL=http://localhost:5173/auth/github/callback

# Operator admin panel: comma-separated emails allowed into GET /admin/metrics.
# Empty means no admins (the panel is closed). Case-insensitive.
PULSE_PLATFORM_ADMINS=

# Cloudflare Access for the admin origin (admin.pulsepager.com). Set both in prod so
# the admin endpoint authorizes off the verified CF Access identity, not an app
# session. Leave empty locally (the admin endpoint then uses the normal session).
# Team domain is your <team>.cloudflareaccess.com; AUD is the Access app's AUD tag.
PULSE_CF_ACCESS_TEAM_DOMAIN=
PULSE_CF_ACCESS_AUD=

# --- transactional email (platform mailer; api + notifier) ---
# Powers org invites, magic-link login, and the team-email alert channel. When
# PULSE_SMTP_HOST is empty the app uses a dev mailer that just logs the message, so
# local dev needs nothing here. In production we use Resend: set HOST to its relay,
# USERNAME to the literal "resend", and PASSWORD to a Resend API key (keep the key in
# your real .env, never commit it). FROM must be on a domain verified in Resend with
# SPF/DKIM/DMARC, or delivery fails. For a quick test you can send from
# onboarding@resend.dev without verifying a domain.
PULSE_SMTP_HOST=
PULSE_SMTP_PORT=587
PULSE_SMTP_USERNAME=resend
PULSE_SMTP_PASSWORD=
PULSE_SMTP_FROM=Pulse Pager <no-reply@pulsepager.com>
# Reputation segmentation (RFC-019): send sign-in / invite mail from an account
# subdomain and alert / channel-test mail from an alerts subdomain, so an alert burst
# can't drag down login deliverability. Each falls back to PULSE_SMTP_FROM when unset,
# so the split is opt-in. Verify each subdomain in Resend (SPF/DKIM/DMARC). Only the
# notifier reads these (it is the single sender).
PULSE_SMTP_FROM_ACCOUNT=Pulse Pager <login@account.pulsepager.com>
PULSE_SMTP_FROM_ALERTS=Pulse Pager <alerts@alerts.pulsepager.com>
PULSE_SMTP_TLS_MODE=starttls

# --- billing (only the billing service reads these, RFC-018) ---
# Provider adapter: "stub" (default, dev/test, no provider account) or "paddle".
PULSE_BILLING_PROVIDER=stub
# Shared secret the inbound webhook signature is verified against. Required for the
# billing service to boot (a missing secret would accept any signature).
PULSE_BILLING_WEBHOOK_SECRET=dev-billing-secret
# Where the billing service serves the webhook (separate from the health addr).
PULSE_BILLING_ADDR=:8081
# Paddle Billing API key (only when PULSE_BILLING_PROVIDER=paddle; skeleton in Phase 1).
PULSE_PADDLE_API_KEY=
