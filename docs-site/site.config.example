# Site identity for the generated legal pages (terms/privacy/refund).
#
# Copy to docs-site/site.config and fill in your real values, OR set these as env
# vars in CI. site.config is gitignored so your legal name never lands in the repo
# (this is an open-source project). build.sh sources this, then renders the legal
# templates. Re-run `make docs` (or docs-site/build.sh) after changing anything.
#
# For Paddle verification you MUST set SELLER_NAME (your Einzelunternehmen / legal
# name, since a sole proprietor's legal name is preferred) and JURISDICTION.

# Product/brand name shown on the pages.
PROJECT_NAME="Pulse Pager"

# The legal seller. For a sole proprietor this is your personal legal name; for a
# company, the registered company name.
SELLER_NAME="Your Legal Name"

# Where buyers reach you for support, privacy, and refund requests.
CONTACT_EMAIL="hi@pulsepager.com"

# Public site origin (no trailing slash).
SITE_URL="https://pulsepager.com"

# Governing-law / place of establishment, e.g. "Germany".
JURISDICTION="Germany"

# Effective / last-updated date shown on the pages (YYYY-MM-DD). Bump it when you
# change the content, not on every build.
EFFECTIVE_DATE="2026-06-24"

# --- Paddle checkout page (checkout.html) ---
# This page is what you set as Paddle's "Default payment link", on a domain you have
# approved in Paddle > Checkout > Approved domains. Paddle opens it as
# <link>?_ptxn=<transaction id> and the page loads Paddle.js to show the payment form.

# Client-side token from Paddle > Authentication > Client-side tokens (starts with
# "live_" or "test_"). This is NOT the secret API key; it is meant for the browser.
PADDLE_CLIENT_TOKEN="live_xxx"

# "production" for live, "sandbox" for the Paddle sandbox.
PADDLE_ENVIRONMENT="production"

# Where Paddle sends the buyer after a successful payment (your app origin).
APP_URL="https://app.pulsepager.com"
