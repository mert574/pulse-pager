{{- /*
  The one branded shell for every Pulse Pager email (alerts, channel test, invite,
  magic-link). Built for email clients, not browsers: tables for layout, inline
  styles only (Gmail strips <style> and <head>), a 600px centered card, and
  bulletproof table-wrapped buttons so Outlook renders them. The logo is an inline
  cid image (see buildMessage), so nothing is fetched or blocked.

  html/template escapes every {{.Field}} for its context, so user-controlled values
  (monitor names, org names, error text) are safe. The `raw` calls emit the Outlook
  conditional comments, which html/template would otherwise strip. The whole palette
  lives here (this template is the presentation layer): page #ece2d2, card #fffdf9,
  header #5b4231, cream #f7efe0, caramel #d98a4f, body #4a3526, heading #3a2a1d,
  muted #8a7257, hairline #ece0cc, zebra #faf5ec.
*/ -}}
{{- /* css-typed so html/template trusts it in the style attributes; an untyped
       string here is filtered to the ZgotmplZ sentinel and the font is lost. Leads
       with system-ui (the standard "OS UI font" keyword) and keeps the vendor names
       as fallbacks for older clients. */ -}}
{{- $font := css "system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif" -}}
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><meta name="color-scheme" content="light"></head>
<body style="margin:0;padding:0;background:#ece2d2;">
{{- if .Preheader}}
<div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">{{.Preheader}}</div>
{{- end}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#ece2d2;">
<tr><td align="center" style="padding:32px 16px;">
{{raw "<!--[if mso]><table role=\"presentation\" width=\"600\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td><![endif]-->"}}
<table role="presentation" align="center" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:600px;background:#fffdf9;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(58,42,29,0.08);">
<tr><td style="background:#5b4231;padding:16px 32px;text-align:center;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
<td style="vertical-align:middle;padding-right:12px;"><img src="{{.LogoSrc}}" width="168" height="168" alt="Pulse Pager" style="display:block;width:168px;height:168px;border:0;outline:none;"></td>
<td style="vertical-align:middle;"><span style="font-family:{{$font}};font-size:24px;font-weight:700;letter-spacing:-0.01em;color:#f7efe0;">Pulse Pager</span></td>
</tr></table>
</td></tr>
<tr><td style="padding:32px;">
{{- with .Banner}}
{{- $c := "#9a5a34"}}{{- $bg := "#f6ecdd"}}
{{- if eq .Tone "down"}}{{$c = "#c0392b"}}{{$bg = "#fbeae7"}}{{end}}
{{- if eq .Tone "ok"}}{{$c = "#1f9254"}}{{$bg = "#e9f6ee"}}{{end}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 20px;"><tr><td style="background:{{$bg | css}};border-radius:999px;padding:7px 16px;font-family:{{$font}};"><span style="color:{{$c | css}};font-size:13px;">&#9679;</span><span style="color:{{$c | css}};font-size:13px;font-weight:700;letter-spacing:0.08em;">&nbsp;{{.Label | upper}}</span></td></tr></table>
{{- end}}
{{- if .Heading}}
<h1 style="margin:0 0 12px;font-family:{{$font}};font-size:22px;line-height:1.3;font-weight:700;color:#3a2a1d;">{{.Heading}}</h1>
{{- end}}
{{- if .Intro}}
<p style="margin:0 0 20px;font-family:{{$font}};font-size:15px;line-height:1.6;color:#4a3526;">{{.Intro}}</p>
{{- end}}
{{- if .Rows}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 4px;">
{{- range $i, $r := .Rows}}
<tr><td style="{{if odd $i}}background:#faf5ec;{{end}}padding:11px 12px;font-family:{{$font}};font-size:13px;color:#8a7257;white-space:nowrap;vertical-align:top;border-radius:6px 0 0 6px;">{{$r.Label}}</td><td style="{{if odd $i}}background:#faf5ec;{{end}}padding:11px 12px;font-family:{{$font}};font-size:14px;font-weight:500;color:#4a3526;word-break:break-word;vertical-align:top;border-radius:0 6px 6px 0;">{{$r.Value}}</td></tr>
{{- end}}
</table>
{{- end}}
{{- with .Button}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:26px 0 4px;"><tr><td align="center" bgcolor="#5b4231" style="border-radius:10px;"><a href="{{.URL}}" target="_blank" style="display:inline-block;padding:14px 30px;font-family:{{$font}};font-size:15px;font-weight:600;line-height:1;color:#f7efe0;text-decoration:none;border-radius:10px;">{{.Label}}</a></td></tr></table>
{{- end}}
{{- if .Note}}
<p style="margin:20px 0 0;font-family:{{$font}};font-size:13px;line-height:1.6;color:#8a7257;">{{.Note}}</p>
{{- end}}
{{- with .Callout}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:24px 0 0;"><tr><td style="background:#faf5ec;border-left:3px solid #d98a4f;border-radius:8px;padding:14px 16px;"><div style="font-family:{{$font}};font-size:12px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;color:#8a7257;margin:0 0 5px;">{{.Title}}</div><div style="font-family:{{$font}};font-size:13px;line-height:1.55;color:#4a3526;">{{.Body}}</div>
{{- if and .LinkURL .LinkLabel}}
<div style="margin-top:8px;"><a href="{{.LinkURL}}" target="_blank" style="font-family:{{$font}};font-size:13px;font-weight:600;color:#d98a4f;text-decoration:none;">{{.LinkLabel}} &rarr;</a></div>
{{- end}}
</td></tr></table>
{{- end}}
</td></tr>
<tr><td style="padding:22px 32px;border-top:1px solid #ece0cc;">
{{- if .Footer}}
<p style="margin:0 0 6px;font-family:{{$font}};font-size:12px;line-height:1.5;color:#8a7257;">{{.Footer}}</p>
{{- end}}
<p style="margin:0;font-family:{{$font}};font-size:12px;line-height:1.5;color:#8a7257;">Pulse Pager &middot; open-source uptime monitoring &middot; <a href="https://pulsepager.com" style="color:#d98a4f;text-decoration:none;">pulsepager.com</a></p>
</td></tr>
</table>
{{raw "<!--[if mso]></td></tr></table><![endif]-->"}}
</td></tr></table>
</body></html>
