# openapi-typescript@7 declares peer typescript@^5, but this repo is on
# typescript@6. The mismatch is metadata only: openapi-typescript emits plain
# .d.ts that compiles fine under TS6 (typecheck passes). Accept the peer range so
# installs do not need an ad-hoc --legacy-peer-deps flag. Drop this once
# openapi-typescript widens its typescript peer to include 6.x.
legacy-peer-deps=true
