{
  "name": "pulse-web",
  "private": true,
  "version": "0.0.0",
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript ../api/openapi/v1.yaml -o src/api/schema.d.ts",
    "lint:api": "spectral lint --ruleset ../api/openapi/.spectral.yaml ../api/openapi/v1.yaml",
    "test": "web-test-runner \"src/**/*.test.ts\"",
    "test:watch": "web-test-runner \"src/**/*.test.ts\" --watch",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lit/context": "^1.1.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tanstack/table-core": "^8.21.3",
    "http-status-codes": "^2.3.0",
    "lit": "^3.3.3",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@stoplight/spectral-cli": "^6.16.0",
    "@tailwindcss/vite": "^4.3.1",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "daisyui": "^5.5.23",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
